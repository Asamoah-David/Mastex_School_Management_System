{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "command": "sh -c 'python manage.py migrate --noinput && gunicorn schoolms.wsgi:application --bind :$PORT --workers 2'"
  }
}
