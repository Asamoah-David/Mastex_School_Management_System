{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/health/",
    "healthcheckTimeout": 300,
    "preDeployCommand": ["/app/scripts/railway-predeploy.sh"],
    "startCommand": "./docker-entrypoint.sh web-only"
  },
  "jobs": {
    "retry_unpaid": {
      "build": false,
      "schedule": "0 2 * * *",
      "command": "python manage.py retry_unpaid",
      "timetable": {
        "timezone": "UTC"
      }
    },
    "check_subscriptions": {
      "build": false,
      "schedule": "0 6 * * *",
      "command": "python manage.py check_subscriptions",
      "timetable": {
        "timezone": "UTC"
      }
    },
    "clearsessions": {
      "build": false,
      "schedule": "0 3 * * 0",
      "command": "python manage.py clearsessions",
      "timetable": {
        "timezone": "UTC"
      }
    }
  }
}
