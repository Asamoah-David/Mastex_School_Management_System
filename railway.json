{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/health/",
    "healthcheckTimeout": 60,
    "command": "sh -c 'python manage.py migrate --noinput && python manage.py createcachetable 2>/dev/null; python manage.py collectstatic --noinput && gunicorn schoolms.wsgi:application --bind 0.0.0.0:$PORT --workers 2 --threads 2 --timeout 120 --max-requests 1000 --max-requests-jitter 50 --access-logfile - --error-logfile -'"
  },
  "jobs": {
    "retry_unpaid": {
      "build": false,
      "schedule": "0 2 * * *",
      "command": "python manage.py retry_unpaid",
      "timetable": {
        "timezone": "UTC"
      }
    },
    "check_subscriptions": {
      "build": false,
      "schedule": "0 6 * * *",
      "command": "python manage.py check_subscriptions",
      "timetable": {
        "timezone": "UTC"
      }
    },
    "clearsessions": {
      "build": false,
      "schedule": "0 3 * * 0",
      "command": "python manage.py clearsessions",
      "timetable": {
        "timezone": "UTC"
      }
    }
  }
}
