# -----------------------------------------------------------------------------
# Mastex SchoolOS — environment template (copy to .env locally; use platform UI in prod)
# Never commit real .env. Placeholders only below.
# -----------------------------------------------------------------------------

# --- ERP / production defaults (built into schoolms.settings; no .env required) ---
# When DEBUG=False:
#   • AUDIT_APPEND_ONLY defaults ON — AuditLog cannot be deleted via admin/ORM (archive + optional prune).
#   • LOG_JSON defaults ON — JSON lines on stdout for log drains (set LOG_JSON=0 for plain text).
# When DEBUG=True (local dev): both default OFF unless you set them to 1/true.
# Opt out of append-only in production only if you must: AUDIT_APPEND_ONLY=0
# E2E tests (settings_e2e) force AUDIT_APPEND_ONLY off regardless.

# --- Core Django ---
# Local default: DEBUG true. On Railway/Render/Fly, DEBUG defaults false if unset.
DEBUG=True
SECRET_KEY=change-me-use-get_random_secret_key
ALLOWED_HOSTS=localhost,127.0.0.1,.railway.app,.up.railway.app
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,https://your-app.up.railway.app
GIT_COMMIT_SHA=

# --- Database (production: use DATABASE_URL) ---
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/POSTGRES_DB
# Or omit DATABASE_URL and set POSTGRES_* when using Docker Compose:
# POSTGRES_DB=schoolms
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=change-me
# POSTGRES_HOST=db
# POSTGRES_PORT=5432

# --- Cache / sessions (optional) ---
# REDIS_URL=redis://default:password@host:6379/0

# --- CORS (required for separate SPA origins when DEBUG=False) ---
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://your-app.up.railway.app

# --- API docs (OpenAPI / Swagger) ---
# API_DOCS_ENABLED=1          # set 0 to disable /api/schema/, /api/docs/, /api/redoc/
# API_DOCS_PUBLIC=0           # when DEBUG=False, default 0 = docs require login (session or JWT)
# REST: POST /api/token/ (JWT) then GET /api/v1/me/, /api/v1/staff-leave/, /api/v1/expenses/, /api/v1/attendance/today/

# --- Outbound webhooks (per-school endpoints in Django admin → Integrations) ---
# INTEGRATIONS_WEBHOOKS_ENABLED=1
# INTEGRATIONS_WEBHOOK_TIMEOUT_SEC=10

# --- TLS behind proxy (Railway/Render set automatically; optional override) ---
# BEHIND_TLS_TERMINATING_PROXY=1
# SECURE_SSL_REDIRECT=0       # default off on detected PaaS; avoid 301 on internal healthchecks

# --- Logging ---
LOG_LEVEL=INFO
# LOG_JSON=1

# --- Sentry (optional) ---
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.0

# --- Email ---
# EMAIL_BACKEND=core.email_backends.SendGridEmailBackend
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@example.com
# ADMIN_NAME=Admin
# ADMIN_EMAIL=ops@example.com
# SENDGRID_API_KEY=

# --- Payments (Paystack) ---
# PAYSTACK_SECRET_KEY=
# PAYSTACK_PUBLIC_KEY=
# Optional; webhook HMAC uses PAYSTACK_SECRET_KEY if unset (Paystack has no separate dashboard "webhook secret").
# PAYSTACK_WEBHOOK_SECRET=
# PAYSTACK_CURRENCY=GHS
# PAYSTACK_PLATFORM_FEE_PERCENT=0
# PAYSTACK_PASS_FEE_TO_PAYER=True
# PAYSTACK_PROCESSING_FEE_PERCENT=1.95
# Outgoing staff salary transfers via Paystack (debits Paystack merchant balance).
# PAYSTACK_STAFF_TRANSFERS_ENABLED=False
# Safety gate: keep False until school-owned funding controls (ledger, reconciliation,
# maker-checker approval) are fully implemented and validated. When False, automated
# staff payouts are blocked even if PAYSTACK_STAFF_TRANSFERS_ENABLED=True.
# PAYSTACK_STAFF_SCHOOL_OWNED_PAYOUTS_READY=False

# --- SMS (mNotify) ---
# MNOTIFY_API_KEY=
# MNOTIFY_SENDER_ID=
# ADMIN_PHONE=
# ADMISSION_STATUS_SMS_ENABLED=1   # 0 disables SMS when admission pipeline status changes (in-app still runs)

# --- Cron / internal jobs ---
# CRON_SECRET_KEY=long-random-string

# --- Compliance / audit trail (audit.AuditLog) ---
# AUDIT_APPEND_ONLY=1              # optional: force ON even in DEBUG, or use AUDIT_APPEND_ONLY=0 to force OFF in prod
# AUDIT_PRUNE_ENABLED=1           # required for prune_audit_logs --execute (or pass --force)
# AUDIT_RETENTION_DAYS=730        # default age for prune_audit_logs when --older-than-days omitted
# AUDIT_ARCHIVE_DIR=/path/to/dir  # default: <project>/var/audit_archive — mount a volume in production
# Example cron: weekly JSONL export, then (if policy allows) prune after backup:
#   0 3 * * 0 cd /app && python manage.py archive_audit_logs --after "$(date -u -d '7 days ago' +%Y-%m-%d)"
#   # python manage.py prune_audit_logs --execute   # only after legal/ops sign-off

# --- In-app notifications (bulk parent/staff pushes) ---
# BULK_IN_APP_NOTIFICATION_CAP=1500   # max recipients per bulk create (clamped 100–5000)

# --- Supabase (optional media uploads) ---
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_STORAGE_BUCKET=media

# --- AI (optional) ---
# GEMINI_API_KEY=
# GROQ_API_KEY=

# --- First deploy only (blank after superuser exists) ---
# DJANGO_SUPERUSER_PASSWORD=

# --- Optional preflight before Gunicorn (Docker) ---
# RUN_PREFLIGHT=0
